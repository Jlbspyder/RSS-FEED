generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String             @id @default(cuid())
  firstName    String?
  lastName     String?
  email        String             @unique
  passwordHash String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  categories   Category[]
  feeds        Feed[]
  articleState UserArticleState[]
  preferences  UserPreference?
}

model Category {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  feeds Feed[]

  @@unique([userId, name])
}

model Feed {
  id            String   @id @default(cuid())
  title         String
  customTitle   String?
  description   String?
  feedUrl       String
  siteUrl       String?
  health        String   @default("active")
  lastFetchedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  articles Article[]

  @@unique([userId, feedUrl])
}

model Article {
  id          String   @id @default(cuid())
  externalId  String?
  title       String
  description String?
  content     String?
  author      String?
  url         String
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  feedId String
  feed   Feed   @relation(fields: [feedId], references: [id], onDelete: Cascade)

  articleState UserArticleState[]

  @@unique([feedId, url])
}

model UserArticleState {
  id           String   @id @default(cuid())
  isRead       Boolean  @default(false)
  isBookmarked Boolean  @default(false)
  readAt       DateTime?
  bookmarkedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId    String
  articleId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model UserPreference {
  id              String   @id @default(cuid())
  layout          String   @default("cards")
  refreshInterval String   @default("manual")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}